# APP CONFIG
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars

# DATABASE CONNECTION (PostgreSQL 18)
# Use 'localhost' for local development (npm run dev)
# Use 'postgres' if running the app via Docker (docker compose up)
DATABASE_URL=postgresql://satoru_sso_user:password@localhost:5432/satoru_sso?sslmode=disable

# REDIS CONNECTION (Redis 8)
# Use 'localhost' for local development (npm run dev)
# Use 'redis' if running the app via Docker (docker compose up)
REDIS_URL=redis://localhost:6379

# DOCKER INITIALIZATION
# These must match the credentials in the connection URLs above
POSTGRES_USER=satoru_sso_user
POSTGRES_PASSWORD=password
POSTGRES_DB=satoru_sso